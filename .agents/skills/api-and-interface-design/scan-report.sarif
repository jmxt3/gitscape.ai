{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/master/Schemata/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "ScapeGuard",
          "version": "2.1.0",
          "informationUri": "https://gitscape.ai",
          "rules": [
            {
              "id": "GS-INJ-001",
              "name": "injection.ignore_previous",
              "shortDescription": {
                "text": "Prompt-injection: attempt to override prior instructions."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "category": "prompt_injection",
                "owasp-ast": [
                  "AST01"
                ],
                "owasp-llm": [
                  "LLM01"
                ],
                "tags": [
                  "prompt_injection",
                  "AST01",
                  "LLM01"
                ]
              }
            },
            {
              "id": "GS-INJ-002",
              "name": "injection.reveal_system_prompt",
              "shortDescription": {
                "text": "Prompt-injection: attempt to exfiltrate the system prompt."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "category": "prompt_injection",
                "owasp-ast": [
                  "AST01"
                ],
                "owasp-llm": [
                  "LLM01"
                ],
